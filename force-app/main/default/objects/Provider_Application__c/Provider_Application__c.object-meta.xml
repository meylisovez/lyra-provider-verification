<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Provider Application</label>
    <pluralLabel>Provider Applications</pluralLabel>
    <description>Object used to track and manage provider applications for verification within the organization.</description>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
    <nameField>
        <label>Provider Application Name</label>
        <type>AutoNumber</type>
        <displayFormat>PA-{0000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
</CustomObject>